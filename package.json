{
  "name": "gsmart",
  "version": "0.14.2",
  "description": "CLI to generate smart commit messages using AI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragnarok22/gsmart.git"
  },
  "homepage": "https://ragnarok22.github.io/gsmart",
  "keywords": [
    "cli",
    "ai",
    "git",
    "gsmart",
    "commit",
    "conventional-commits",
    "openai",
    "anthropic",
    "gemini",
    "mistral"
  ],
  "bugs": {
    "url": "https://github.com/ragnarok22/gsmart/issues"
  },
  "author": "Reinier Hernández <sasuke.reinier@gmail.com>",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gsmart": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "node prebuild.js",
    "build": "tsup",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "test": "node --import ./test-support/register-esmock.mjs --import tsx --test --test-reporter=dot test/*.test.ts",
    "test:coverage": "pnpm test && node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout test/completions.test.ts test/config-command.test.ts test/config.test.ts test/debug.test.ts test/git.test.ts test/holiday.test.ts test/index.test.ts test/login.test.ts test/openai-oauth.test.ts test/prompt-config.test.ts test/providers.test.ts test/reset.test.ts test/setup-env.test.ts test/version-check-coverage.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "pretypecheck": "node prebuild.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.64",
    "ai": "^6.0.184",
    "chalk": "5.6.2",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/prompts": "^2.4.9",
    "@types/update-notifier": "^6.0.8",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "esmock": "^2.7.5",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
