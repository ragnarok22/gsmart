{
  "name": "gsmart",
  "version": "0.13.2",
  "description": "CLI to generate smart commit messages using AI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragnarok22/gsmart.git"
  },
  "homepage": "https://ragnarok22.github.io/gsmart",
  "keywords": [
    "cli",
    "ai",
    "git",
    "gsmart",
    "commit",
    "conventional-commits",
    "openai",
    "anthropic",
    "gemini",
    "mistral"
  ],
  "bugs": {
    "url": "https://github.com/ragnarok22/gsmart/issues"
  },
  "author": "Reinier Hernández <sasuke.reinier@gmail.com>",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gsmart": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "node prebuild.js",
    "build": "tsup",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "pretypecheck": "node prebuild.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/mistral": "^3.0.34",
    "@ai-sdk/openai": "^3.0.60",
    "ai": "^6.0.175",
    "chalk": "5.6.2",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/prompts": "^2.4.9",
    "@types/update-notifier": "^6.0.8",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "esmock": "^2.7.4",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
