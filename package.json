{
  "name": "gsmart",
  "version": "0.13.1",
  "description": "CLI to generate smart commit messages using AI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragnarok22/gsmart.git"
  },
  "homepage": "https://ragnarok22.github.io/gsmart",
  "keywords": [
    "cli",
    "ai",
    "git",
    "gsmart",
    "commit",
    "conventional-commits",
    "openai",
    "anthropic",
    "gemini",
    "mistral"
  ],
  "bugs": {
    "url": "https://github.com/ragnarok22/gsmart/issues"
  },
  "author": "Reinier Hernández <sasuke.reinier@gmail.com>",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gsmart": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "node prebuild.js",
    "build": "tsup",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "pretypecheck": "node prebuild.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.48",
    "ai": "^6.0.138",
    "chalk": "5.6.2",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/prompts": "^2.4.9",
    "@types/update-notifier": "^6.0.8",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "esmock": "^2.7.3",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
